# Bridge Server
MATRIX_WS_PORT=7999
MATRIX_PTY_SOURCE=pipe          # pipe | extension | node-pty
# MATRIX_PTY_PIPE=/tmp/cc-matrix-pipe   # auto-detected from os.tmpdir() if not set
MATRIX_BUFFER_SIZE=10000        # lines to buffer for reconnect replay

# GUI
MATRIX_WS_URL=ws://localhost:7999
MATRIX_ALWAYS_ON_TOP=true
MATRIX_OPACITY=0.95
MATRIX_RAIN_SPEED=1.0
MATRIX_RAIN_DENSITY=0.7

# Future Control
MATRIX_COMMAND_ENABLED=false    # explicit unlock required
